P={"geishaId":"M04"}
点数=6
実績=Pと点数のM05得点半減を実行。
期待=6
"M05得点6(非適用)"と実績と期待の検証を実行。

赤客={"name":"紅葉の客","color":"red","income":2,"condition":0}
青客={"name":"青い客","color":"blue","income":1,"condition":0}

P0={"geishaId":"M04","zashiki":[]}
P1={"geishaId":"M01","zashiki":[赤客]}
G={"players":[P0,P1]}
技情報={"targetPID":1,"targetCardIndex":0}
Gと0と""と技情報の舞妓04技実行をGに代入。
実績=G["players"][0]["zashiki"]の要素数
期待=1
"才能の秋風(取得)"と実績と期待の検証を実行。
実績=G["players"][1]["zashiki"]の要素数
期待=0
"才能の秋風(対象減少)"と実績と期待の検証を実行。
実績=G["players"][0]["zashiki"][0]["color"]
期待="red"
"才能の秋風(色)"と実績と期待の検証を実行。

P0={"geishaId":"M04","zashiki":[]}
P1={"geishaId":"M01","zashiki":[青客]}
G={"players":[P0,P1]}
Gと0と""と技情報の舞妓04技実行をGに代入。
実績=G["players"][0]["zashiki"]の要素数
期待=0
"才能の秋風(非取得)"と実績と期待の検証を実行。
実績=G["players"][1]["zashiki"]の要素数
期待=1
"才能の秋風(対象残)"と実績と期待の検証を実行。

# 舞妓01テスト（手札全捨て→同枚数ドロー）
手札1={"name":"町人","color":"red","condition":1,"income":2,"promo":1}
手札2={"name":"商人","color":"blue","condition":4,"income":4,"promo":1}
山札1={"name":"侍","color":"red","condition":6,"income":5,"promo":1}
山札2={"name":"盗人","color":"green","condition":4,"income":4,"promo":1}
P0={"geishaId":"M01","hand":[手札1,手札2],"effectFlags":{"extraAdAvailable":0},"zashiki":[],"ad":[],"reputation":{"red":0,"blue":0,"green":0},"closed":0}
G={"players":[P0],"deck":[山札1,山札2],"discard":[]}
技情報={}
Gと0と""と技情報の舞妓01技実行をGに代入。
実績=G["players"][0]["hand"]の要素数
想定=2
"舞妓01(手札枚数維持)"と実績と想定の検証を実行。
実績=G["players"][0]["hand"][0]["name"]
想定="侍"
"舞妓01(新手札内容)"と実績と想定の検証を実行。
実績=G["discard"]の要素数
想定=2
"舞妓01(捨て札枚数)"と実績と想定の検証を実行。

