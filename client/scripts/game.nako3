# ─── ゲーム画面初期化（後半ベース＋前半の芸者画像設定をマージ）──
●（stateで）ゲーム画面初期化とは
  # turnIndexをwindowに保存（プレイヤー表示内で参照するため）
  TI＝state["turnIndex"]。
  JS文＝「window.__currentTurnIndex = 」＆TI。
  JS文をJS実行。

  # currentPhaseをwindowに保存（予約客セット判定で参照するため）
  PHASE＝state["phase"]。
  JS文2＝「window.__currentPhase = '」＆PHASE＆「'」。
  JS文2をJS実行。

  players＝state["players"]。
  myPID＝「parseInt(sessionStorage.getItem('myPlayerId'))」をJS実行。
  myP＝players[myPID]。

  # 芸者画像設定
  geisha＝myP["geisha"]。
  gImg＝geisha["image"]。
  もし gImg ならば
    JS文＝「document.getElementById('my-maiko-img').src = '」＆gImg＆「'; document.getElementById('my-maiko-area').style.display = 'flex';」。
    JS文をJS実行。
    # ステータス（評判）表示
    rep＝geisha["reputation"]。
    rR＝rep["red"]。
    rB＝rep["blue"]。
    rG＝rep["green"]。
    STATHTML＝「」。
    STATHTML＝STATHTML＆「<div class='maiko-stat-row'><div class='stat-box red'></div>」＆rR＆「</div>」。
    STATHTML＝STATHTML＆「<div class='maiko-stat-row'><div class='stat-box blue'></div>」＆rB＆「</div>」。
    STATHTML＝STATHTML＆「<div class='maiko-stat-row'><div class='stat-box green'></div>」＆rG＆「</div>」。
    EL＝「#my-maiko-stats」のDOM要素取得。
    ELへSTATHTMLをHTML設定。
  違えば
    「document.getElementById('my-maiko-area').style.display = 'none';」をJS実行。
  ここまで。

  # ラウンド数表示
  ラウンド数＝state["round"]。
  EL＝「#round-num」のDOM要素取得。
  ELへラウンド数をテキスト設定。

  # 全プレイヤー表示
  playersでプレイヤー表示。

  # 自分の手札表示
  myP["hand"]で手札表示。

  # 座敷・宣伝表示
  playersで座敷表示。
  playersで宣伝表示。

  # スコア表示
  SCORE＝myP["tokenTotal"]。
  SEL＝「#my-score」のDOM要素取得。
  SELへSCOREをテキスト設定。

  # 局数表示
  R＝state["round"]。
  GEL＝「#game-progress」のDOM要素取得。
  GELへR＆「/3」をテキスト設定。

  # 予約客スロット表示
  予約カード＝myP["reservation"]。
  予約カードで予約客スロット表示。

  # hasReservationフラグ同期
  HAS＝myP["hasReservation"]。
  JS文＝「window.__hasReservation = 」＆HAS。
  JS文をJS実行。

  # スロットクリックイベント初期化（1回だけ）
  既存フラグ＝「window.__reservationBtnInit || 0」をJS実行。
  もし 既存フラグ＝0 ならば
    SLOT＝「#reservation-slot」のDOM要素取得。
    もし SLOT≠空 ならば
      SLOTをクリックした時には
        CURPHASE＝「window.__currentPhase || ''」をJS実行。
        もし CURPHASE＝「reservation」 ならば
          予約客セット処理。
        ここまで。
      ここまで。
    ここまで。
    『window.__reservationBtnInit = 1』をJS実行。
  ここまで。

  # フェーズ別UI制御
  もし PHASE＝「reservation」 ならば
    # バナー表示
    BAN＝「#reservation-banner」のDOM要素取得。
    もし BAN≠空 ならば
      BANの「display」へ「block」をDOMスタイル設定。
    ここまで。
    # アクションボタン無効
    0でアクションボタン有効設定。
    # 予約客スロットをクリック可能に
    SLOT＝「#reservation-slot」のDOM要素取得。
    もし SLOT≠空 ならば
      もし HAS＝0 ならば
        SLOTの「cursor」へ「pointer」をDOMスタイル設定。
      ここまで。
    ここまで。
  違えば
    # バナー非表示
    BAN＝「#reservation-banner」のDOM要素取得。
    もし BAN≠空 ならば
      BANの「display」へ「none」をDOMスタイル設定。
    ここまで。
    # 手番チェック
    turnIdx＝state["turnIndex"]。
    もし turnIdx＝myPID ならば
      1でアクションボタン有効設定。
      myP["hand"]とmyP["reputation"]で出せるカードハイライト。
    違えば
      0でアクションボタン有効設定。
    ここまで。
  ここまで。

  # 山札残枚数表示
  DECK＝state["deckCount"]。
  DEL＝「#deck-count-display」のDOM要素取得。
  もし DEL≠空 ならば
    DELへ「山札: 」＆DECK＆「枚」をテキスト設定。
  ここまで。

  # 最終巡バッジ
  FINALLAP＝state["isFinalLap"]。
  FBADGE＝「#final-lap-badge」のDOM要素取得。
  もし FBADGE≠空 ならば
    もし FINALLAP＝1 ならば
      FBADGEの「display」へ「inline」をDOMスタイル設定。
    違えば
      FBADGEの「display」へ「none」をDOMスタイル設定。
    ここまで。
  ここまで。
ここまで。