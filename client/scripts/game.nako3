# ─── アクション実行はサブ関数の後に定義 ───────────────

●アクション実行とは
  action＝「window.__actionType」をJS実行。
  もし action＝「座敷」 ならば
    座敷処理。
  ここまで。
  もし action＝「宣伝」 ならば
    宣伝処理。
  ここまで。
  もし action＝「紹介」 ならば
    紹介処理。
  ここまで。
  もし action＝「予約客」 ならば
    予約客処理。
  ここまで。
ここまで。

# ─── 画面初期化は最後に定義 ────────────────────────
●（stateで）ゲーム画面初期化とは
  # turnIndexをwindowに保存
  TI＝state["turnIndex"]。
  JS文＝「window.__currentTurnIndex = 」＆TI。
  JS文をJS実行。

  players＝state["players"]。
  myPID＝「parseInt(sessionStorage.getItem('myPlayerId'))」をJS実行。

  # myPIDに一致するプレイヤーを検索
  myP＝空。
  players を反復して
    もし 対象["id"]＝myPID ならば
      myP＝対象。
    ここまで。
  ここまで。
  もし myP＝空 ならば
    戻る。
  ここまで。

  PHASE＝state["phase"]。

  # 効果選択UI用にwindowに保存
  HANDJSON＝myP["hand"]をJSONエンコード。
  JS文＝「window.__currentHand = 」＆HANDJSON。
  JS文をJS実行。
  PLAYERSJSON＝playersをJSONエンコード。
  JS文＝「window.__currentPlayers = 」＆PLAYERSJSON。
  JS文をJS実行。

  # ラウンド数表示
  ラウンド数＝state["round"]。
  EL＝「#round-num」のDOM要素取得。
  ELへラウンド数をテキスト設定。

  # 全プレイヤー表示
  playersでプレイヤー表示。
  # 自分の手札表示
  myP["hand"]で手札表示。
  # 座敷・宣伝表示
  playersで座敷表示。
  playersで宣伝表示。

  # スコア表示
  SCORE＝myP["tokenTotal"]。
  SEL＝「#my-score」のDOM要素取得。
  SELへSCOREをテキスト設定。

  # 局数表示
  R＝state["round"]。
  GEL＝「#game-progress」のDOM要素取得。
  GELへR＆「/3」をテキスト設定。

  # 予約客スロット表示
  予約カード＝myP["reservation"]。
  予約カードで予約客スロット表示。

  # hasReservationフラグ同期
  HAS＝myP["hasReservation"]。
  JS文＝「window.__hasReservation = 」＆HAS。
  JS文をJS実行。

  # イベント初期化（1回だけ）
  既存フラグ＝「window.__reservationBtnInit || 0」をJS実行。
  もし 既存フラグ＝0 ならば
    『window.__reservationBtnInit = 1』をJS実行。
  ここまで。
  # フェーズ別UI制御
  もし PHASE＝「reservation」 ならば
    # バナー表示
    BAN＝「#reservation-banner」のDOM要素取得。
    もし BAN≠空 ならば
      BAN の「display」へ「block」をDOMスタイル設定。
    ここまで。
    # アクションボタン無効
    0でアクションボタン有効設定。
    # 予約客スロットをクリック可能に
    SLOT＝「#reservation-slot」のDOM要素取得。
    もし SLOT≠空 ならば
      もし HAS＝0 ならば
        SLOT の「cursor」へ「pointer」をDOMスタイル設定。
        SLOT をクリックした時には
          予約客セット処理。
        ここまで。
      ここまで。
    ここまで。
  違えば
    # バナー非表示
    BAN＝「#reservation-banner」のDOM要素取得。
    もし BAN≠空 ならば
      BAN の「display」へ「none」をDOMスタイル設定。
    ここまで。
    # 手番チェック
    turnIdx＝state["turnIndex"]。
    もし turnIdx＝myPID ならば
      1でアクションボタン有効設定。
      myP["hand"]とmyP["reputation"]で出せるカードハイライト。
    違えば
      0でアクションボタン有効設定。
    ここまで。
  ここまで。
   # 山札残枚数表示
  DECK＝state["deckCount"]。
  DEL＝「#deck-count-display」のDOM要素取得。
  もし DEL≠空 ならば
    DELへ「山札: 」＆DECK＆「枚」をテキスト設定。
  ここまで。

  # 最終巡バッジ
  FINALLAP＝state["isFinalLap"]。
  FBADGE＝「#final-lap-badge」のDOM要素取得。
  もし FBADGE≠空 ならば
    もし FINALLAP＝1 ならば
      FBADGEの「display」へ「inline」をDOMスタイル設定。
    違えば
      FBADGEの「display」へ「none」をDOMスタイル設定。
    ここまで。
  ここまで。
ここまで。